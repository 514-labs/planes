{
  "name": "e2e-tests",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:preview": "dotenv -e .env.local.preview -- vitest run",
    "test:e2e": "vitest run tests/moose-api.e2e.test.ts",
    "test:e2e:preview": "dotenv -e .env.local.preview -- vitest run tests/moose-api.e2e.test.ts",
    "test:perf": "vitest run tests/moose-performance.e2e.test.ts",
    "test:perf:preview": "dotenv -e .env.local.preview -- vitest run tests/moose-performance.e2e.test.ts",
    "test:correctness": "vitest run tests/moose-correctness.e2e.test.ts",
    "test:correctness:preview": "dotenv -e .env.local.preview -- vitest run tests/moose-correctness.e2e.test.ts"
  },
  "dependencies": {
    "@514labs/moose-lib": "^0.6.435",
    "planes-moose": "workspace:*"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "vitest": "^3.2.4"
  }
}
